{
  "name": "accountant24",
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun run scripts/build.ts",
    "build:all": "bun run scripts/build.ts --all",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "verify": "biome check --write . && biome check . && bunx tsc --noEmit && bun run test --coverage",
    "eval": "bun run evals/run.ts",
    "pre-commit": "biome check --write . && biome check .",
    "release": "bun run scripts/release.ts",
    "release:dry": "bun run scripts/release.ts --dry-run",
    "prepare": "bunx simple-git-hooks"
  },
  "simple-git-hooks": {
    "commit-msg": "bunx commitlint --edit $1",
    "pre-commit": "bun run pre-commit"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "header-max-length": [
        2,
        "always",
        72
      ],
      "body-max-line-length": [
        1,
        "always",
        100
      ],
      "scope-enum": [
        2,
        "always",
        [
          "tools",
          "commands",
          "skills"
        ]
      ]
    }
  },
  "changelog": {
    "repo": "machulav/accountant24",
    "noAuthors": true,
    "types": {
      "feat": {
        "title": "🚀 Features",
        "semver": "minor"
      },
      "fix": {
        "title": "🐞 Bug Fixes",
        "semver": "patch"
      },
      "perf": {
        "title": "⚡ Performance",
        "semver": "patch"
      },
      "refactor": {
        "title": "♻️ Refactors",
        "semver": "patch"
      },
      "revert": {
        "title": "⏪ Reverts",
        "semver": "patch"
      },
      "build": {
        "title": "📦 Build",
        "semver": "patch"
      },
      "docs": {
        "title": "📖 Documentation"
      },
      "chore": {
        "title": "🏡 Chore"
      },
      "test": {
        "title": "✅ Tests"
      },
      "style": {
        "title": "🎨 Styles"
      },
      "ci": {
        "title": "🤖 CI"
      }
    }
  },
  "piConfig": {
    "name": "accountant24",
    "configDir": ".accountant24"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@napi-rs/canvas": "^0.1.97",
    "diff": "^8.0.4",
    "file-type": "^22.0.0",
    "pdfjs-dist": "5.4.296",
    "tesseract.js": "^7.0.0",
    "unpdf": "^1.4.0",
    "zod": "^3.24.0"
  },
  "overrides": {
    "signal-exit": "3.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "changelogen": "^0.6.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.8.0"
  }
}

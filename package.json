{
  "name": "accountant24",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "accountant24": "src/index.ts",
    "a24": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "verify": "biome check --write . && biome check . && bunx tsc --noEmit && bun run test --coverage",
    "eval": "bun run evals/run.ts"
  },
  "piConfig": {
    "name": "accountant24",
    "configDir": ".accountant24"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "zod": "^3.24.0"
  },
  "overrides": {
    "signal-exit": "3.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  }
}

{
  "name": "accountant24",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "accountant24": "src/index.ts",
    "a24": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "verify": "biome check --write . && biome check . && bunx tsc --noEmit && bun run test --coverage",
    "eval": "bun run evals/run.ts",
    "pre-commit": "biome check --write . && biome check .",
    "release": "bunx changelogen --release --push",
    "release:dry": "bunx changelogen --release --no-commit --no-tag",
    "prepare": "bunx simple-git-hooks"
  },
  "simple-git-hooks": {
    "commit-msg": "bunx commitlint --edit $1",
    "pre-commit": "bun run pre-commit"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "piConfig": {
    "name": "accountant24",
    "configDir": ".accountant24"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "diff": "^8.0.4",
    "zod": "^3.24.0"
  },
  "overrides": {
    "signal-exit": "3.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "changelogen": "^0.6.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.8.0"
  }
}

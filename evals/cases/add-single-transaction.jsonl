{"id":"tool-params-add-coffee-001","input":{"messages":[{"role":"user","content":"Add yesterday's $12 coffee at Starbucks"}]},"expected":{"ledger_contains":[{"payee":"Starbucks","amount":12,"currency":"USD"}],"rubric":"Agent adds the transaction with payee 'Starbucks', amount $12, and a date that is yesterday relative to the current date."},"grading":"rubric","metadata":{"category":"tool_params","tags":["add_transaction","date_parsing","amount"],"difficulty":"easy","source":"manual"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Default currency is USD"]},"ledger":{"accounts":["account Assets:Checking","account Expenses:Food:Coffee"],"transactions":[["2026-03-10 * Starbucks | Latte","Expenses:Food:Coffee  5.50 USD","Assets:Checking"]]}}}
{"id":"multi-step-add-and-validate-001","input":{"messages":[{"role":"user","content":"Add a $200 rent payment and then check if the journal still validates"}]},"expected":{"ledger_contains":[{"payee":"John","amount":200,"currency":"USD"}],"tools_called":["validate"],"rubric":"Agent adds the rent transaction and then validates the journal. Both must happen."},"grading":"rubric","metadata":{"category":"multi_step","tags":["add_transaction","validate","workflow"],"difficulty":"medium","source":"manual"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Landlord is John","Monthly rent is $200","Default currency is USD"]},"ledger":{"accounts":["account Assets:Checking","account Expenses:Housing:Rent","commodity 1000.00 USD"],"transactions":[["2026-02-01 * John | Rent","Expenses:Housing:Rent  200.00 USD","Assets:Checking"]]}}}
{"id":"error-handling-unknown-account-001","input":{"messages":[{"role":"user","content":"Add a transaction to expenses:nonexistent_account_xyz"}]},"expected":{"tools_not_called":["bash"],"rubric":"Agent should inform the user the account doesn't exist and suggest closest matching accounts. Must not silently create a new account."},"grading":"rubric","metadata":{"category":"error_handling","tags":["add_transaction","account_resolution"],"difficulty":"medium","source":"manual"},"setup":{"ledger":{"accounts":["account Assets:Checking","account Expenses:Food:Groceries","account Expenses:Food:Coffee","account Expenses:Housing:Rent"]}}}
{"id":"tool-selection-no-mapping-in-memory-001","input":{"messages":[{"role":"user","content":"I spent $15 at Blue Bottle"}]},"expected":{"ledger_contains":[{"payee":"Blue Bottle","amount":15,"currency":"USD","account":"Coffee"}],"tools_not_called":["update_memory"],"rubric":"Agent adds the transaction with the correct category from ledger history (Expenses:Food:Coffee). Must NOT store a payee-to-account mapping in memory — the ledger is the source of truth."},"grading":"rubric","metadata":{"category":"tool_selection","tags":["add_transaction","query","no_auto_mapping"],"difficulty":"easy","source":"real_conversation"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Default currency is USD"]},"ledger":{"accounts":["account Assets:Checking","account Expenses:Food:Coffee"],"transactions":[["2026-03-01 * Blue Bottle | Coffee","Expenses:Food:Coffee  6.00 USD","Assets:Checking"]]}}}
{"id":"tool-params-unknown-payee-001","input":{"messages":[{"role":"user","content":"I've spent 40 EUR for grosseries, but I don't remember the name of the shop"}]},"expected":{"ledger_contains":[{"payee":"Unknown","amount":40,"currency":"EUR","account":"Groceries"}],"rubric":"Agent uses payee 'Unknown' since the user explicitly said they don't remember. Should not ask for the payee name."},"grading":"rubric","metadata":{"category":"tool_params","tags":["payee","unknown","missing_info","expense"],"difficulty":"easy","source":"manual"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Default currency is EUR"]},"ledger":{"accounts":["account Assets:Checking","account Expenses:Food:Groceries"]}}}
{"id":"multi-step-unknown-payee-conversation-001","input":{"messages":[{"role":"user","content":"I spent 50 EUR on groceries"},{"role":"assistant","content":"What is the name of the payee or store?"},{"role":"user","content":"I don't know"}]},"expected":{"ledger_contains":[{"payee":"Unknown","amount":50,"currency":"EUR"}],"rubric":"After the user says they don't know the payee, the agent should proceed with 'Unknown' without asking again."},"grading":"rubric","metadata":{"category":"multi_step","tags":["payee","unknown","missing_info","expense","conversation_flow"],"difficulty":"medium","source":"manual"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Default currency is EUR"]},"ledger":{"accounts":["account Assets:Checking","account Expenses:Food:Groceries"]}}}

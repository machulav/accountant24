{"id":"multi-step-lookup-category-unknown-payee-001","input":{"messages":[{"role":"user","content":"I spent 30 EUR at SomeNewShop123"}]},"expected":{"tools_not_called":["add_transaction"],"rubric":"Agent should determine that SomeNewShop123 has no established category (not found in ledger) and ask the user which expense category to use. Must not guess or assume a category."},"grading":"rubric","metadata":{"category":"multi_step","tags":["category","unknown_payee","clarification"],"difficulty":"medium","source":"manual"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Default currency is EUR"]},"ledger":{"accounts":["account Assets:Checking","account Expenses:Food:Groceries","account Expenses:Shopping"],"transactions":[["2026-03-01 * Rewe | Groceries","Expenses:Food:Groceries  30.00 EUR","Assets:Checking"]]}}}
{"id":"reasoning-ambiguous-category-001","input":{"messages":[{"role":"user","content":"I spent 30 EUR at Amazon"}]},"expected":{"tools_not_called":["add_transaction"],"rubric":"Agent should recognize that Amazon has been used under multiple expense categories (electronics, books, household) and ask the user which category to use for this transaction. Must not arbitrarily pick one."},"grading":"rubric","metadata":{"category":"reasoning","tags":["category","ambiguous","clarification"],"difficulty":"medium","source":"manual"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Default currency is EUR"]},"ledger":{"accounts":["account Assets:Checking","account Expenses:Electronics","account Expenses:Books","account Expenses:Household"],"transactions":[["2026-02-10 * Amazon | Headphones","Expenses:Electronics  80.00 EUR","Assets:Checking"],["2026-02-20 * Amazon | Books","Expenses:Books  25.00 EUR","Assets:Checking"],["2026-03-05 * Amazon | Cleaning supplies","Expenses:Household  15.00 EUR","Assets:Checking"]]}}}
{"id":"tool-params-default-account-from-memory-001","input":{"messages":[{"role":"user","content":"I've spent 30 EUR at NewCafe for coffee"}]},"expected":{"ledger_contains":[{"payee":"NewCafe","amount":30,"currency":"EUR"}],"rubric":"Agent uses the default spending account from memory (Assets:Checking) without asking. Category is explicitly provided by user."},"grading":"rubric","metadata":{"category":"tool_params","tags":["memory","default_account","expense"],"difficulty":"medium","source":"manual"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Default currency is EUR"]},"ledger":{"accounts":["account Assets:Checking","account Expenses:Food:Coffee"]}}}
{"id":"reasoning-auto-assign-category-from-ledger-001","input":{"messages":[{"role":"user","content":"I spent 25 EUR at Rewe from savings"}]},"expected":{"ledger_contains":[{"payee":"Rewe","amount":25,"currency":"EUR","account":"Groceries"}],"tools_not_called":["update_memory"],"rubric":"Agent determines the correct category from ledger history (Rewe → Expenses:Food:Groceries) and uses the user-specified account (Assets:Savings), not the memory default."},"grading":"rubric","metadata":{"category":"reasoning","tags":["category","auto_assign","ledger_lookup"],"difficulty":"medium","source":"manual"},"setup":{"ledger":{"accounts":["account Assets:Checking","account Assets:Savings","account Expenses:Food:Groceries"],"transactions":[["2026-02-05 * Rewe | Groceries","Expenses:Food:Groceries  45.00 EUR","Assets:Checking"],["2026-02-12 * Rewe | Groceries","Expenses:Food:Groceries  32.00 EUR","Assets:Checking"],["2026-03-01 * Rewe | Groceries","Expenses:Food:Groceries  55.00 EUR","Assets:Checking"]]}}}
{"id":"tool-params-all-info-provided-001","input":{"messages":[{"role":"user","content":"I spent 30 EUR at Starbucks from checking for coffee"}]},"expected":{"ledger_contains":[{"payee":"Starbucks","amount":30,"currency":"EUR"}],"rubric":"Agent adds the transaction immediately without asking any clarifying questions. All information is provided upfront."},"grading":"rubric","metadata":{"category":"tool_params","tags":["add_transaction","complete_info","no_clarification"],"difficulty":"easy","source":"manual"},"setup":{"ledger":{"accounts":["account Assets:Checking","account Expenses:Food:Coffee"]}}}
{"id":"multi-step-full-auto-memory-and-ledger-001","input":{"messages":[{"role":"user","content":"I spent 15 EUR at Rewe"}]},"expected":{"ledger_contains":[{"payee":"Rewe","amount":15,"currency":"EUR","account":"Groceries"}],"rubric":"Agent adds the transaction with the correct account and category with zero clarification questions."},"grading":"rubric","metadata":{"category":"multi_step","tags":["memory","ledger_lookup","auto_assign","zero_clarification"],"difficulty":"medium","source":"manual"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Default currency is EUR"]},"ledger":{"accounts":["account Assets:Checking","account Expenses:Food:Groceries"],"transactions":[["2026-02-05 * Rewe | Groceries","Expenses:Food:Groceries  45.00 EUR","Assets:Checking"],["2026-02-12 * Rewe | Groceries","Expenses:Food:Groceries  32.00 EUR","Assets:Checking"]]}}}
{"id":"tool-params-explicit-account-overrides-memory-001","input":{"messages":[{"role":"user","content":"I spent 30 EUR at Starbucks from savings for coffee"}]},"expected":{"ledger_contains":[{"payee":"Starbucks","amount":30,"currency":"EUR","account":"Savings"}],"rubric":"Agent uses Assets:Savings (the explicitly specified account), NOT Assets:Checking from memory. User's explicit instruction always overrides memory defaults."},"grading":"rubric","metadata":{"category":"tool_params","tags":["memory","account_override","explicit_input"],"difficulty":"medium","source":"manual"},"setup":{"memory":{"facts":["Default spending account is Assets:Checking","Default currency is EUR"]},"ledger":{"accounts":["account Assets:Checking","account Assets:Savings","account Expenses:Food:Coffee"]}}}

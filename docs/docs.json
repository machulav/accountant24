{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Accountant24",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": ["index", "docs/use-cases", "docs/quickstart"]
      },
      {
        "group": "Features",
        "pages": ["docs/skills"]
      },
      {
        "group": "Guides",
        "pages": ["docs/go-fully-local"]
      },
      {
        "group": "Resources",
        "pages": ["docs/comparison", "docs/faq"]
      }
    ]
  },
  "redirects": [
    { "source": "/use-cases", "destination": "/docs/use-cases" },
    { "source": "/quickstart", "destination": "/docs/quickstart" },
    { "source": "/skills", "destination": "/docs/skills" },
    { "source": "/go-fully-local", "destination": "/docs/go-fully-local" },
    { "source": "/comparison", "destination": "/docs/comparison" },
    { "source": "/faq", "destination": "/docs/faq" }
  ],
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/machulav/accountant24"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/machulav/accountant24"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "seo": {
    "metatags": {
      "og:site_name": "Accountant24",
      "og:type": "website",
      "og:url": "https://accountant24.ai",
      "twitter:card": "summary_large_image",
      "theme-color": "#16A34A"
    }
  }
}
